generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js required models ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Plan & trial
  plan          Plan      @default(FREE)
  trialEndsAt   DateTime?

  // Stripe
  stripeCustomerId       String? @unique
  stripeSubscriptionId   String? @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // Usage (for FREE plan monthly limit)
  simulationsThisMonth Int      @default(0)
  simulationsResetAt   DateTime @default(now())

  accounts    Account[]
  sessions    Session[]
  simulations SimulationSession[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Dicto models ───────────────────────────────────────────────────────────

enum Plan {
  FREE
  TRIAL
  PRO
}

model SimulationSession {
  id               String   @id @default(cuid())
  userId           String?
  jobTitle         String
  company          String
  experienceLevel  ExperienceLevel
  score            Int?
  strongPoint      String?  @db.Text
  improvementPoint String?  @db.Text
  completedAt      DateTime?
  createdAt        DateTime @default(now())

  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  questions SimulationQuestion[]

  @@map("simulation_sessions")
}

model SimulationQuestion {
  id         String   @id @default(cuid())
  sessionId  String
  question   String   @db.Text
  orderIndex Int
  createdAt  DateTime @default(now())

  session SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer  SimulationAnswer?

  @@map("simulation_questions")
}

model SimulationAnswer {
  id         String   @id @default(cuid())
  questionId String   @unique
  answer     String   @db.Text
  feedback   String?  @db.Text
  createdAt  DateTime @default(now())

  question SimulationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("simulation_answers")
}

enum ExperienceLevel {
  NO_EXPERIENCE
  SOME_EXPERIENCE
  EXPERIENCED
}
