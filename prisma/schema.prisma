generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js required models ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Plan & trial
  plan          Plan      @default(FREE)
  trialEndsAt   DateTime?

  // Stripe
  stripeCustomerId       String? @unique
  stripeSubscriptionId   String? @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // Usage (for FREE plan monthly limit)
  simulationsThisMonth Int      @default(0)
  simulationsResetAt   DateTime @default(now())

  // Onboarding
  onboardingCompletedAt DateTime?

  // Gamification
  username       String?  @unique
  bio            String?
  points         Int      @default(0)
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActivityAt DateTime?

  accounts         Account[]
  sessions         Session[]
  simulations      SimulationSession[]
  profile          UserProfile?
  badges           UserBadge[]
  pointEvents      PointEvent[]
  groupMembers     GroupMember[]
  trainingPlans    TrainingPlan[]
  ownedGroups      Group[]             @relation("GroupOwner")
  tasksCreated     GroupTask[]         @relation("TaskCreator")
  tasksAssigned    GroupTask[]         @relation("TaskAssignee")
  activityLogs     GroupActivityLog[]  @relation("ActivityActor")
  notifications    Notification[]

  @@map("users")
}

model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Step 1 — contexto de uso
  contextos          String[]

  // Step 2 — perfil profissional
  curso              String?
  semestre           String?
  formado            Boolean  @default(false)
  nivelAutopercebido String?

  // Step 3 — objetivo imediato
  objetivoImediato   String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("user_profiles")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Dicto models ───────────────────────────────────────────────────────────

enum Plan {
  FREE
  TRIAL
  PRO
}

model SimulationSession {
  id               String   @id @default(cuid())
  userId           String?
  tipo             String   @default("ENTREVISTA_ESTAGIO")
  config           Json?

  // campos legados — entrevista de estágio
  jobTitle         String   @default("")
  company          String   @default("")
  experienceLevel  ExperienceLevel @default(NO_EXPERIENCE)
  pesquisaEmpresa  String?

  score            Int?
  strongPoint      String?  @db.Text
  improvementPoint String?  @db.Text
  dicaAcionavel    String?  @db.Text
  resumoGeral      String?  @db.Text
  completedAt      DateTime?
  createdAt        DateTime @default(now())

  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  questions SimulationQuestion[]

  @@map("simulation_sessions")
}

model SimulationQuestion {
  id         String   @id @default(cuid())
  sessionId  String
  question   String   @db.Text
  orderIndex Int
  createdAt  DateTime @default(now())

  session SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer  SimulationAnswer?

  @@map("simulation_questions")
}

model SimulationAnswer {
  id         String   @id @default(cuid())
  questionId String   @unique
  answer     String   @db.Text
  feedback   String?  @db.Text
  createdAt  DateTime @default(now())

  question SimulationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("simulation_answers")
}

enum ExperienceLevel {
  NO_EXPERIENCE
  SOME_EXPERIENCE
  EXPERIENCED
}

// ─── Gamification ────────────────────────────────────────────────────────────

enum BadgeType {
  BATMAN
  GALO
  POLVO
  MARATONISTA
  SPEEDRUN
  SEM_DORMIR
  CHAD
  NPC_NAO
  GIGACHAD
  MAIN_CHARACTER
  SKILL_ISSUE_RESOLVIDO
}

model UserBadge {
  id       String    @id @default(cuid())
  userId   String
  badge    BadgeType
  earnedAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge])
  @@map("user_badges")
}

model PointEvent {
  id        String   @id @default(cuid())
  userId    String
  points    Int
  reason    String   // "daily_checkin" | "simulation_complete" | "group_activity"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_events")
}

// ─── Groups ───────────────────────────────────────────────────────────────────

model Group {
  id            String    @id @default(cuid())
  name          String
  description   String?
  discipline    String?
  imageUrl      String?
  deliveryDate  DateTime?
  ownerId       String
  inviteCode    String    @unique @default(cuid())
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastStreakAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  owner        User               @relation("GroupOwner", fields: [ownerId], references: [id])
  members      GroupMember[]
  projects     GroupProject[]
  tasks        GroupTask[]
  activityLogs GroupActivityLog[]

  @@map("groups")
}

model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

enum GroupRole {
  MEMBER
  ADMIN
}

model GroupProject {
  id               String    @id @default(cuid())
  groupId          String
  title            String
  presentationDate DateTime?
  createdAt        DateTime  @default(now())

  group Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  parts GroupProjectPart[]

  @@map("group_projects")
}

model GroupProjectPart {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  title     String
  createdAt DateTime @default(now())

  project GroupProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("group_project_parts")
}

// ─── Group Tasks & Activity Log ───────────────────────────────────────────────

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum ActivityAction {
  GROUP_CREATED
  MEMBER_ADDED
  TASK_CREATED
  TASK_ASSIGNED
  TASK_COMPLETED
}

model GroupTask {
  id           String     @id @default(cuid())
  groupId      String
  title        String
  deadline     DateTime?
  assignedToId String?
  status       TaskStatus @default(OPEN)
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy  User             @relation("TaskCreator", fields: [createdById], references: [id])
  assignedTo User?            @relation("TaskAssignee", fields: [assignedToId], references: [id])
  logs       GroupActivityLog[]

  @@map("group_tasks")
}

model GroupActivityLog {
  id        String         @id @default(cuid())
  groupId   String
  taskId    String?
  actorId   String
  action    ActivityAction
  detail    String?
  createdAt DateTime       @default(now())

  group Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  task  GroupTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actor User       @relation("ActivityActor", fields: [actorId], references: [id])

  @@map("group_activity_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  groupId   String?
  taskId    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Training Plan ────────────────────────────────────────────────────────────

model TrainingPlan {
  id           String   @id @default(cuid())
  userId       String
  title        String
  targetDate   DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  days TrainingPlanDay[]

  @@map("training_plans")
}

model TrainingPlanDay {
  id          String    @id @default(cuid())
  planId      String
  dayNumber   Int
  date        DateTime
  focus       String
  description String?   @db.Text
  completed   Boolean   @default(false)
  completedAt DateTime?

  plan TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("training_plan_days")
}
