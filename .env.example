# ─── Database (Neon) ────────────────────────────────────────────────────────────
# Obtenha em: console.neon.tech → seu projeto → Connection string
DATABASE_URL=""

# ─── Auth.js v5 ─────────────────────────────────────────────────────────────────
# Gere com: node -e "require('crypto').randomBytes(32).toString('base64')|console.log"
AUTH_SECRET=""

# Google OAuth — console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend — resend.com/api-keys
AUTH_RESEND_KEY=""

# ─── Claude API ─────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=""

# ─── Stripe ─────────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=""
# dashboard.stripe.com → Developers → Webhooks → seu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=""
# ID do price PRO (R$ 19,90/mês) — dashboard.stripe.com → Products
STRIPE_PRICE_ID_PRO=""

# ─── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Demo mode ───────────────────────────────────────────────────────────────────
# true  → usa perguntas e feedback pré-definidos (sem chamar a Claude API)
# false → chamada real à API (padrão em produção)
DEMO_MODE="false"
